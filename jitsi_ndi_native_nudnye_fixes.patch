 #if JNN_HAS_NDI
 
+#include <mutex>
 #include <Processing.NDI.Lib.h>
 
+namespace {
+
+std::mutex g_ndiRuntimeMutex;
+int g_ndiRuntimeUsers = 0;
+
+bool acquireNdiRuntime() {
+ std::lock_guard<std::mutex> lock(g_ndiRuntimeMutex);
+ if (g_ndiRuntimeUsers == 0 && !NDIlib_initialize()) {
+  return false;
+ }
+ ++g_ndiRuntimeUsers;
+ return true;
+}
+
+void releaseNdiRuntime() {
+ std::lock_guard<std::mutex> lock(g_ndiRuntimeMutex);
+ if (g_ndiRuntimeUsers <= 0) {
+  return;
+ }
+ --g_ndiRuntimeUsers;
+ if (g_ndiRuntimeUsers == 0) {
+  NDIlib_destroy();
+ }
+}
+
+} // namespace
+
 #endif
 
